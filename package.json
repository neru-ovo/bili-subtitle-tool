{
  "name": "bilibili-subtitle-summarizer",
  "version": "1.0.0",
  "description": "B站视频AI字幕爬取与内容总结工具",
  "type": "module",
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
    "dev:frontend": "vite",
    "dev:backend": "nodemon api/server.ts",
    "build": "vite build",
    "start": "node dist/server.js",
    "check": "tsc --noEmit",
    "deploy": "wrangler pages deploy dist"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "autoprefixer": "^10.4.16",
    "axios": "^1.6.0",
    "cheerio": "^1.0.0-rc.12",
    "playwright": "^1.60.0",
    "postcss": "^8.4.32",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "concurrently": "^8.2.2",
    "gh-pages": "^6.1.0",
    "nodemon": "^3.0.2",
    "ts-node": "^10.9.2"
  }
}
